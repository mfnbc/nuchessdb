{
  database: {
    path: "./data/nuchessdb.sqlite"
    schema: "./sql/schema.sql"
  }
  identity: {
    me: {
      chesscom: ""
      lichess: ""
    }
  }
  enrichment: {
    critter: {
      # binary is unused — critter eval runs in-process via the Rust plugin (chessdb critter-eval).
      # Kept here only for forward-compatibility if an external binary path is ever needed.
      # binary: ""
      name: "critter-eval"
      model: ""
    }
    dynamic: {
      binary: ""
      engine_name: "lc0"
      elo_tune: 1200
      depth: 12
    }
    engine: {
      binary: ""
      name: "stockfish"
      model: ""
      # threads, hash_mb, and nodes are not currently passed to the UCI process.
      # They are reserved for future use when multi-threaded / hash-tuned engine eval is implemented.
      # threads: 1
      # hash_mb: 128
      # nodes: 0
      depth: 12
      movetime_ms: 0
    }
    # llm_model and prompt_version are reserved for future LLM-assisted annotation.
    # No module currently reads these fields.
    # llm_model: ""
    # prompt_version: ""
  }
}
